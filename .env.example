# Database Configuration
POSTGRES_DB=mytourdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DB_PORT=5432

# Application Configuration
APP_PORT=8080
UI_PORT=4200
CORS_ALLOWED_ORIGINS=http://localhost:4200

# OpenRouteService Directions API
# Leave ORS_API_KEY empty for local demo fallback routing.
ORS_ENABLED=true
ORS_BASE_URL=https://api.openrouteservice.org
ORS_API_KEY=
ORS_CONNECT_TIMEOUT=3s
ORS_READ_TIMEOUT=10s
ORS_BIKE_PROFILE=cycling-regular
ORS_HIKE_PROFILE=foot-hiking
ORS_RUNNING_PROFILE=foot-walking
ORS_VACATION_PROFILE=driving-car
